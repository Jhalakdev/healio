generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ──────────────────────────────────────────

enum Role {
  PATIENT
  DOCTOR
  ADMIN
  SUPER_ADMIN
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum BookingMode {
  INSTANT
  SCHEDULED
}

enum TransactionType {
  CREDIT
  DEBIT
  REFUND
}

enum PaymentStatus {
  SUCCESS
  FAILED
  PENDING
}

enum MessageType {
  TEXT
  IMAGE
  VOICE
  FILE
}

enum ReportType {
  PDF
  IMAGE
}

// ─── USERS ──────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  phone     String?  @unique
  email     String?  @unique
  password  String?
  role      Role
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctor       Doctor?
  patient      Patient?
  wallets      Wallet[]
  sentMessages Message[] @relation("sender")

  @@map("users")
}

model Patient {
  id          String   @id @default(cuid())
  userId      String   @unique
  name        String?
  dob         DateTime?
  gender      String?
  height      String?  // "5.8 in" / "175 cm"
  weight      String?  // "70 kg"
  bloodGroup  String?  // "B+", "O-", etc.
  avatarUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user           User               @relation(fields: [userId], references: [id])
  bookings       Booking[]          @relation("patientBookings")
  reports        Report[]
  subscriptions  PatientPlan[]
  reviews        Review[]
  familyMembers  FamilyMember[]
  favourites     FavouriteDoctor[]
  labOrders      LabOrder[]

  @@map("patients")
}

model FamilyMember {
  id              String   @id @default(cuid())
  patientId       String   // owner of the family group
  linkedUserId    String?  // if this member has their own account, link it here
  name            String
  relation        String   // "self", "spouse", "child", "parent", "sibling"
  isChild         Boolean  @default(false)
  dob             DateTime  // REQUIRED: age computed from this dynamically
  gender          String?
  bloodGroup      String?
  photoUrl        String?
  phoneNumber     String?  // required if age >= 18
  isVerified      Boolean  @default(false) // phone verified for 18+
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  patient  Patient   @relation(fields: [patientId], references: [id])
  bookings Booking[] @relation("memberBookings")

  @@unique([patientId, phoneNumber]) // same phone can't be added twice in same family
  @@map("family_members")
}

model FavouriteDoctor {
  id        String   @id @default(cuid())
  patientId String
  doctorId  String
  createdAt DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id])
  doctor  Doctor  @relation(fields: [doctorId], references: [id])

  @@unique([patientId, doctorId])
  @@map("favourite_doctors")
}

// Specialists (doctor types: Cardiologist, Neurologist, etc.)
model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  icon      String?  // emoji fallback
  imageUrl  String?  // uploaded icon/illustration
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctors  DoctorCategory[]
  symptoms SymptomSpecialist[]

  @@map("categories")
}

// Symptoms/Diseases (patient problems: Headache, Breathing problem, etc.)
model Symptom {
  id          String   @id @default(cuid())
  name        String   @unique  // "Headache", "Irregular Periods", "Breathing Problem"
  description String?
  icon        String?  // emoji fallback
  imageUrl    String?  // uploaded icon
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  specialists SymptomSpecialist[]

  @@map("symptoms")
}

// Links symptoms to specialists (Headache → Neurologist, General Medicine)
model SymptomSpecialist {
  id         String @id @default(cuid())
  symptomId  String
  categoryId String

  symptom  Symptom  @relation(fields: [symptomId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])

  @@unique([symptomId, categoryId])
  @@map("symptom_specialists")
}

// Many-to-many: a doctor can have multiple specializations/degrees
model DoctorCategory {
  id         String   @id @default(cuid())
  doctorId   String
  categoryId String
  createdAt  DateTime @default(now())

  doctor   Doctor   @relation(fields: [doctorId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])

  @@unique([doctorId, categoryId])
  @@map("doctor_categories")
}

model Doctor {
  id                 String             @id @default(cuid())
  userId             String             @unique
  name               String
  qualifications     String[]           // multiple degrees
  specialization     String?            // legacy
  categoryId         String?            // legacy
  onboardingStep     Int                @default(0) // 0=not started, 1=profile done, 2=specializations done, 3=documents uploaded, 4=submitted, 5=approved
  experience         Int?               // years
  consultationFee    Decimal            @default(0) @db.Decimal(10, 2)
  bio                String?
  avatarUrl          String?
  // Payment details
  upiId              String?            // e.g. "doctor@upi"
  bankAccountNo      String?
  bankIfsc           String?
  bankName           String?
  accountHolderName  String?
  verificationStatus VerificationStatus @default(PENDING)
  rejectionReason    String?            // why the doctor was rejected (mandatory on rejection)
  verifiedAt         DateTime?          // when approved
  isOnline           Boolean            @default(false)
  lastSeenAt         DateTime?
  maxSessionsPerDay  Int                @default(20)
  timezone           String             @default("Asia/Kolkata")
  stateMedicalCouncilNo String?
  documentsUrl       String[]           // legacy field
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  avgResponseMin     Int?               // avg response time in minutes
  categories DoctorCategory[]  // multiple specializations
  user      User              @relation(fields: [userId], references: [id])
  payouts   DoctorPayout[]
  bookings  Booking[]         @relation("doctorBookings")
  slots     DoctorSlot[]
  documents DoctorDocument[]
  reviews   Review[]
  favouritedBy FavouriteDoctor[]

  @@map("doctors")
}

model DoctorDocument {
  id        String   @id @default(cuid())
  doctorId  String
  type      String   // "mbbs_certificate" | "registration_id" | "state_council" | "other"
  fileName  String
  fileUrl   String
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  doctor Doctor @relation(fields: [doctorId], references: [id])

  @@map("doctor_documents")
}

// ─── DOCTOR SCHEDULING ──────────────────────────────

model DoctorSlot {
  id        String   @id @default(cuid())
  doctorId  String
  dayOfWeek Int      // 0=Sunday, 6=Saturday
  startTime String   // "09:00"
  endTime   String   // "17:00"
  isBreak   Boolean  @default(false)
  createdAt DateTime @default(now())

  doctor Doctor @relation(fields: [doctorId], references: [id])

  @@map("doctor_slots")
}

// ─── BOOKINGS ───────────────────────────────────────

model Booking {
  id            String        @id @default(cuid())
  patientId     String
  doctorId      String
  forMemberId   String?       // if booking is for a family member
  mode          BookingMode
  status        BookingStatus @default(PENDING)
  scheduledAt   DateTime
  startedAt     DateTime?
  endedAt       DateTime?
  durationMin   Int           @default(15)
  extended      Boolean       @default(false)
  rescheduled   Boolean       @default(false)
  cancelReason  String?
  livekitRoom   String?       @unique
  amountCharged Decimal       @default(0) @db.Decimal(10, 2)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Pre-consult intake
  symptoms    String?
  medications String?

  // Payment
  couponCode  String?
  discount    Decimal       @default(0) @db.Decimal(10, 2)
  paidViaPlan Boolean       @default(false)

  patient       Patient        @relation("patientBookings", fields: [patientId], references: [id])
  doctor        Doctor         @relation("doctorBookings", fields: [doctorId], references: [id])
  reports       Report[]
  prescription  Prescription?
  messages      Message[]
  transactions  Transaction[]
  review        Review?
  forMember     FamilyMember?  @relation("memberBookings", fields: [forMemberId], references: [id])

  @@index([doctorId, scheduledAt])
  @@index([patientId, status])
  @@map("bookings")
}

// ─── FINANCIAL ──────────────────────────────────────

model Wallet {
  id        String   @id @default(cuid())
  userId    String
  balance   Decimal  @default(0) @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId])
  @@map("wallets")
}

model Transaction {
  id          String          @id @default(cuid())
  userId      String
  bookingId   String?
  amount      Decimal         @db.Decimal(10, 2)
  type        TransactionType
  status      PaymentStatus   @default(SUCCESS)
  description String?
  metadata    Json?           // flexible extra data
  createdAt   DateTime        @default(now())

  booking Booking? @relation(fields: [bookingId], references: [id])

  @@index([userId, createdAt])
  @@index([bookingId])
  @@map("transactions")
}

// ─── REPORTS & PRESCRIPTIONS ────────────────────────

model Report {
  id           String     @id @default(cuid())
  bookingId    String?
  patientId    String
  fileUrl      String
  fileName     String
  fileType     ReportType
  uploadedBy   String     // userId
  expiresAt    DateTime?  // deadline for upload (e.g., 10 days after consultation)
  createdAt    DateTime   @default(now())

  // Doctor reply to this report
  doctorReply      String?   // text reply
  doctorVoiceUrl   String?   // voice note reply
  doctorRepliedAt  DateTime? // when doctor replied
  doctorId         String?   // which doctor replied

  booking Booking? @relation(fields: [bookingId], references: [id])
  patient Patient  @relation(fields: [patientId], references: [id])

  @@map("reports")
}

model Prescription {
  id        String   @id @default(cuid())
  bookingId String   @unique
  fileUrl   String?
  content   String?  // text content, auto-converted to PDF
  notes     String?
  voiceUrl  String?
  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id])

  @@map("prescriptions")
}

// ─── REVIEWS & RATINGS ──────────────────────────────

model Review {
  id        String   @id @default(cuid())
  bookingId String   @unique
  doctorId  String
  patientId String
  rating    Int      // 1-5 stars
  comment   String?
  isAnonymous Boolean @default(false)
  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id])
  doctor  Doctor  @relation(fields: [doctorId], references: [id])
  patient Patient @relation(fields: [patientId], references: [id])

  @@index([doctorId, createdAt])
  @@map("reviews")
}

// ─── MESSAGING ──────────────────────────────────────

model Message {
  id          String      @id @default(cuid())
  bookingId   String
  senderId    String
  type        MessageType @default(TEXT)
  content     String
  fileUrl     String?
  status      String      @default("sent") // "sent" | "delivered" | "read" | "played" (for voice)
  deliveredAt DateTime?
  readAt      DateTime?
  playedAt    DateTime?   // for voice messages: when recipient played it
  createdAt   DateTime    @default(now())

  booking Booking @relation(fields: [bookingId], references: [id])
  sender  User    @relation("sender", fields: [senderId], references: [id])

  @@index([bookingId, createdAt])
  @@map("messages")
}

// ─── LAB TESTS ──────────────────────────────────────

// Lab test providers (LabsAdvisor, Thyrocare, etc.)
model LabProvider {
  id        String   @id @default(cuid())
  name      String   @unique // "LabsAdvisor", "Thyrocare"
  apiKey    String?
  apiSecret String?
  baseUrl   String?
  isActive  Boolean  @default(true)
  commission Decimal @default(0) @db.Decimal(5, 2) // % we pay them
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tests  LabTest[]
  orders LabOrder[]

  @@map("lab_providers")
}

// Available lab tests (synced from provider API or manually added)
model LabTest {
  id          String   @id @default(cuid())
  providerId  String
  name        String   // "Complete Blood Count (CBC)"
  code        String?  // provider's test code
  category    String   // "Blood Test", "Urine Test", "Full Body Checkup", "Thyroid Panel"
  description String?
  mrp         Decimal  @db.Decimal(10, 2) // original price
  sellingPrice Decimal @db.Decimal(10, 2) // our price to patient
  costPrice   Decimal  @db.Decimal(10, 2) // what we pay provider (B2B price)
  turnaround  String?  // "6 hours", "24 hours", "48 hours"
  fasting     Boolean  @default(false) // requires fasting?
  homeCollection Boolean @default(true)
  isPackage   Boolean  @default(false) // true = multiple tests bundled
  testsIncluded String[] // if package: ["CBC", "Thyroid", "Lipid Profile"]
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  provider LabProvider @relation(fields: [providerId], references: [id])
  orders   LabOrderItem[]

  @@map("lab_tests")
}

// Lab test order (patient books or doctor orders)
model LabOrder {
  id              String   @id @default(cuid())
  orderNumber     String   @unique @default(cuid())
  patientId       String
  doctorId        String?  // null if self-booked by patient
  forMemberId     String?  // if booking for family member
  providerId      String
  status          String   @default("pending") // pending | confirmed | sample_collected | processing | report_ready | delivered | cancelled
  totalMrp        Decimal  @db.Decimal(10, 2)
  totalAmount     Decimal  @db.Decimal(10, 2) // what patient paid
  totalCostPrice  Decimal  @db.Decimal(10, 2) // what we pay provider
  profit          Decimal  @db.Decimal(10, 2) // our margin
  paymentMethod   String   @default("wallet") // wallet | razorpay
  paidViaPlan     Boolean  @default(false)
  couponCode      String?
  discount        Decimal  @default(0) @db.Decimal(10, 2)
  // Collection details
  collectionDate  DateTime?
  collectionTime  String?  // "09:00 AM - 11:00 AM"
  collectionAddress String?
  collectionCity  String?
  collectionPincode String?
  // Patient details
  patientName     String
  patientAge      Int?
  patientGender   String?
  patientPhone    String?
  // Tracking
  providerOrderId String?  // order ID from lab provider
  phlebotomistName String?
  phlebotomistPhone String?
  sampleCollectedAt DateTime?
  reportReadyAt   DateTime?
  notes           String?  // doctor's notes or special instructions
  bookingId       String?  // linked consultation (if doctor ordered)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  patient  Patient      @relation(fields: [patientId], references: [id])
  provider LabProvider  @relation(fields: [providerId], references: [id])
  items    LabOrderItem[]
  reports  LabReport[]

  @@index([patientId, status])
  @@index([status, createdAt])
  @@map("lab_orders")
}

// Individual tests in an order
model LabOrderItem {
  id        String  @id @default(cuid())
  orderId   String
  testId    String
  testName  String
  price     Decimal @db.Decimal(10, 2)
  costPrice Decimal @db.Decimal(10, 2)

  order LabOrder @relation(fields: [orderId], references: [id])
  test  LabTest  @relation(fields: [testId], references: [id])

  @@map("lab_order_items")
}

// Lab reports (PDF files)
model LabReport {
  id          String   @id @default(cuid())
  orderId     String
  fileName    String
  fileUrl     String   // stored on R2
  reportType  String   @default("final") // "partial" | "final"
  uploadedAt  DateTime @default(now())

  order LabOrder @relation(fields: [orderId], references: [id])

  @@map("lab_reports")
}

// ─── ADMIN ──────────────────────────────────────────

model AppConfig {
  id    String @id @default(cuid())
  key   String @unique
  value Json
  updatedAt DateTime @updatedAt

  @@map("app_configs")
}

model Faq {
  id        String   @id @default(cuid())
  question  String
  answer    String
  category  String   @default("general") // "general" | "booking" | "payment" | "doctor"
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("faqs")
}

model CmsPage {
  id        String   @id @default(cuid())
  slug      String   @unique // "terms", "privacy", "refund", "about"
  title     String
  content   String   // HTML or markdown
  updatedAt DateTime @updatedAt

  @@map("cms_pages")
}

model Banner {
  id        String   @id @default(cuid())
  title     String
  subtitle  String?
  imageUrl  String?
  linkUrl   String?  // deep link or URL
  target    String   @default("all") // "all" | "patient" | "doctor"
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime @default(now())

  @@map("banners")
}

model Coupon {
  id             String    @id @default(cuid())
  code           String    @unique
  discountType   String    // "flat" | "percentage" | "upto"
  discountValue  Decimal   @db.Decimal(10, 2) // amount or % value
  maxDiscountAmt Decimal?  @db.Decimal(10, 2) // for "upto" type: max discount cap
  minOrderAmt    Decimal?  @db.Decimal(10, 2) // minimum order to apply
  maxUsage       Int       @default(0) // 0 = unlimited
  usedCount      Int       @default(0)
  perUserLimit   Int       @default(1) // max times one user can use
  applicablePlans String[] // plan IDs this coupon works with (empty = all plans)
  applicableFor  String    @default("all") // "all" | "consultation" | "plan_purchase"
  description    String?
  expiresAt      DateTime?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())

  @@map("coupons")
}

model Plan {
  id                  String   @id @default(cuid())
  name                String
  type                String   @default("single") // "single" | "family" | "yearly"
  price               Decimal  @db.Decimal(10, 2)
  consultations       Int      // number of consultations included
  maxMembers          Int      @default(1) // 1 for single, 3 or 5 for family
  validityDays        Int
  childDiscountPercent Decimal @default(10) @db.Decimal(5, 2) // % discount when child added
  description         String?
  features            String[] // ["Unlimited chat", "Priority booking", etc.]
  isActive            Boolean  @default(true)
  sortOrder           Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  subscriptions PatientPlan[]

  @@map("plans")
}

// Patient's purchased plan (tracks remaining consultations)
model PatientPlan {
  id                    String   @id @default(cuid())
  patientId             String
  planId                String
  consultationsRemaining Int
  consultationsUsed     Int      @default(0)
  expiresAt             DateTime
  isActive              Boolean  @default(true)
  razorpayOrderId       String?
  createdAt             DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id])
  plan    Plan    @relation(fields: [planId], references: [id])

  @@index([patientId, isActive])
  @@map("patient_plans")
}

// ─── PAYMENTS (RAZORPAY) ────────────────────────────

model RazorpayOrder {
  id              String   @id @default(cuid())
  userId          String
  razorpayOrderId String   @unique
  razorpayPaymentId String?
  amount          Decimal  @db.Decimal(10, 2)
  currency        String   @default("INR")
  status          String   @default("created") // created | paid | failed
  purpose         String   // "wallet_topup" | "plan_purchase"
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@map("razorpay_orders")
}

// ─── ADMIN PERMISSIONS ──────────────────────────────

model AdminPermission {
  id        String   @id @default(cuid())
  userId    String
  module    String   // "doctors" | "bookings" | "finance" | "analytics" | "coupons" | "plans" | "settings" | "users"
  canRead   Boolean  @default(true)
  canWrite  Boolean  @default(false)
  canDelete Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([userId, module])
  @@map("admin_permissions")
}

// ─── DOCTOR PAYOUTS ─────────────────────────────────

model DoctorPayout {
  id                String   @id @default(cuid())
  doctorId          String
  amount            Decimal  @db.Decimal(10, 2)
  periodStart       DateTime // e.g. Monday
  periodEnd         DateTime // e.g. Sunday
  status            String   @default("pending") // "pending" | "processing" | "completed" | "failed"
  razorpayPayoutId  String?
  upiId             String?
  bookingCount      Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  doctor Doctor @relation(fields: [doctorId], references: [id])

  @@index([doctorId, status])
  @@map("doctor_payouts")
}

// ─── NOTIFICATIONS ──────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "appointment_update" | "payment" | "new_service" | "reschedule" | "report" | "prescription"
  title     String
  body      String
  data      Json?    // { bookingId, doctorId, etc. }
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead, createdAt])
  @@map("notifications")
}

// ─── AUDIT ──────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([entity, entityId])
  @@map("audit_logs")
}
