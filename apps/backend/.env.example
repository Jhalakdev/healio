# Database (local Docker / Neon for production)
DATABASE_URL="postgresql://healio:healio_dev@localhost:5432/healio?schema=public"

# JWT
JWT_SECRET="change-me"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-me"
JWT_REFRESH_EXPIRES_IN="7d"

# Redis (local Docker / Upstash for production)
REDIS_URL="redis://localhost:6379"

# Cloudflare R2
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="healio-uploads"
R2_PUBLIC_URL=""

# LiveKit
LIVEKIT_API_URL="http://localhost:7880"
LIVEKIT_API_KEY="devkey"
LIVEKIT_API_SECRET="secret"

# OTP
OTP_EXPIRY_SECONDS=300
NODE_ENV="development"

# App
PORT=3000
CORS_ORIGINS="http://localhost:3001,http://localhost:8081"

# Consultation defaults
DEFAULT_CONSULTATION_DURATION_MINUTES=15
EXTENSION_DURATION_MINUTES=5
